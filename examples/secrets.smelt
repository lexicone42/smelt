resource db "main" : aws.rds.Instance {
  @intent "Primary application database"
  @owner "platform-team"
  @constraint "Must use encryption at rest"

  identity {
    name = "app-db-prod"
  }

  reliability {
    backup_retention_period = 7
    multi_az = true
  }

  security {
    master_password = secret("super-secret-password-123!")
    master_username = "admin"
    storage_encrypted = true
  }

  sizing {
    allocated_storage = 100
    instance_class = "db.r6g.large"
  }
}
