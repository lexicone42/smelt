resource vpc "test" : aws.ec2.Vpc {
  @intent "Temporary VPC for live integration test"
  @owner "smelt-dev"

  identity {
    name = "smelt-live-test"
    tags = { environment = "test", managed_by = "smelt" }
  }

  network {
    cidr_block = "10.99.0.0/16"
    dns_hostnames = true
    dns_support = true
  }
}

resource subnet "test" : aws.ec2.Subnet {
  @intent "Public subnet for test instance"

  needs vpc.test -> vpc_id

  identity {
    name = "smelt-test-subnet"
  }

  network {
    availability_zone = "us-west-2a"
    cidr_block = "10.99.1.0/24"
    public_ip_on_launch = true
  }
}

resource igw "test" : aws.ec2.InternetGateway {
  @intent "Internet gateway for test VPC"

  needs vpc.test -> vpc_id

  identity {
    name = "smelt-test-igw"
  }
}

resource sg "test" : aws.ec2.SecurityGroup {
  @intent "Minimal security group - no inbound, all outbound"

  needs vpc.test -> vpc_id

  identity {
    description = "Smelt live test - no inbound access"
    name = "smelt-test-sg"
  }
}

resource compute "test" : aws.ec2.Instance {
  @intent "Cheapest possible instance to verify smelt works end-to-end"
  @lifecycle "ephemeral"

  needs sg.test -> group_id
  needs subnet.test -> subnet_id

  identity {
    name = "smelt-live-test"
  }

  sizing {
    ami_id = "ami-03caad32a158f72db"
    instance_type = "t3.nano"
  }
}
