#!/usr/bin/env bash
set -euo pipefail

# Use exo-self preflight for standard Rust checks (fmt, clippy --fix, fmt cleanup)
if command -v preflight &>/dev/null; then
    echo "==> preflight (fmt + clippy)"
    preflight
else
    echo "==> cargo fmt"
    cargo fmt
    echo "==> cargo clippy --fix"
    cargo clippy --fix --allow-dirty --allow-staged --all-targets 2>/dev/null || true
    echo "==> cargo fmt (post-clippy)"
    cargo fmt
fi

echo "==> cargo test"
cargo test

echo "==> cargo deny check"
cargo deny check

echo "==> smelt fmt --check"
if [ -n "$(find . -name '*.smelt' -not -path './.smelt/*' 2>/dev/null)" ]; then
    cargo run --quiet -- fmt --check
fi

echo "pre-commit checks passed"
